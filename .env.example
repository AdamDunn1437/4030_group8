# Copy to .env and edit values for your machine.

# Required: absolute path to your Mario Kart Wii game file (.iso/.wbfs/.rvz)
DOLPHIN_ISO_PATH=C:/Users/OMAR/Downloads/Emulator Stuff/Game Folders/Wii+Gamecube Games/Mario Kart.wbfs

# Optional: absolute path to Dolphin executable (Windows example)
# DOLPHIN_EXE_PATH=C:/Program Files/Dolphin-x64/Dolphin.exe

# Optional: Dolphin user directory (Windows default is typically under Documents)
# DOLPHIN_USER_DIR=C:/Users/OMAR/Documents/Dolphin Emulator

# Optional: savestate to load on reset (F1 loader in current env code)
# DOLPHIN_SAVESTATE=C:/Users/OMAR/Documents/Dolphin Emulator/StateSaves/RMCE01.s01

# Recommended for headless verification
DOLPHIN_GFX_BACKEND=Null
DOLPHIN_MEMORY_BACKEND=dme